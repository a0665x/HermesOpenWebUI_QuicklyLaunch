# Copy values to ~/.hermes/.env or export them before ./run.sh install/up.
# Do not commit real secrets.

# Required by Hermes API server and injected into Open WebUI as OpenAI-compatible key.
# Leave empty and run.sh install will generate one in ~/.hermes/.env.
API_SERVER_KEY=

# Optional model provider keys for Hermes itself.
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=

# Optional overrides
# HERMES_REPO_URL=https://github.com/NousResearch/hermes-agent.git
# HERMES_REF=main
# TS_HOSTNAME=agx-openwebui
# OPENWEBUI_CONTAINER=open-webui
# OPENWEBUI_LOCAL_URL=http://127.0.0.1:3000
